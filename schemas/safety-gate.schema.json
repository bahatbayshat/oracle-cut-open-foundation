{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oracle-cut-open-foundation.dev/schemas/safety-gate.schema.json",
  "title": "SafetyGateInput",
  "type": "object",
  "required": [
    "phaseName",
    "providerCallsAllowed",
    "mediaGenerationAllowed",
    "autoApprovalAllowed",
    "humanApprovalRequired",
    "evidenceProvided"
