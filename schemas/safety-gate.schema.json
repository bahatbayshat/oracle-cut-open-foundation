      "type": "string",
      "minLength": 1
    },
    "providerCallsAllowed": {
      "type": "boolean"
    },
    "mediaGenerationAllowed": {
      "type": "boolean"
    },
    "autoApprovalAllowed": {
      "type": "boolean"
    },
    "humanApprovalRequired": {
      "type": "boolean"
    },
    "evidenceProvided": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}